generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                                                         String                      @id(map: "User_pkey") @default(uuid())
  nif                                                        String?                     @unique(map: "User_nif_key")
  name                                                       String
  email                                                      String                      @unique(map: "User_email_key")
  password                                                   String
  birthDate                                                  DateTime?                   @db.Date
  role                                                       String
  isActive                                                   Boolean                     @default(true)
  createdAt                                                  DateTime                    @default(now())
  updatedAt                                                  DateTime                    @updatedAt
  updatedBy                                                  String?
  notifications                                              notifications[]
  occurrences                                                occurrences[]
  reserve_classrooms                                         reserve_classrooms[]
  student_referral_comments                                  student_referral_comments[]
  student_referrals_student_referrals_assigned_to_idTousers  student_referrals[]         @relation("student_referrals_assigned_to_idTousers")
  student_referrals_student_referrals_created_by_idTousers   student_referrals[]         @relation("student_referrals_created_by_idTousers")
  student_referrals_student_referrals_finalized_by_idTousers student_referrals[]         @relation("student_referrals_finalized_by_idTousers")
}

model classes {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  class_name    String    @db.VarChar(255)
  course_id     String    @db.Uuid
  archived      Int?
  data_archived DateTime? @db.Timestamptz(6)
  upgrade_by_id String?   @db.Uuid
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  courses       courses   @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_classes_course")
  classes       classes?  @relation("classesToclasses", fields: [upgrade_by_id], references: [id], onUpdate: NoAction)
  other_classes classes[] @relation("classesToclasses")

  @@unique([class_name, course_id])
}

model classrooms {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @db.VarChar(150)
  capacity           Int?
  type               String?              @db.VarChar(100)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @db.Timestamptz(6)
  reserve_classrooms reserve_classrooms[]
}

model courses {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String     @db.VarChar(150)
  color      String?    @db.VarChar(50)
  updated_at DateTime?  @default(now()) @db.Timestamp(6)
  created_at DateTime?  @default(now()) @db.Timestamp(6)
  classes    classes[]
  students   students[]
}

model students {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  course_id           String        @db.Uuid
  class_id            String        @db.Uuid
  registration_number String?       @unique @db.VarChar(50)
  name                String        @db.VarChar(150)
  position            String?       @db.VarChar(100)
  rg                  String?       @db.VarChar(20)
  cpf                 String?       @db.VarChar(20)
  birth_date          DateTime?     @db.Date
  mobile_phone        String?       @db.VarChar(20)
  phone               String?       @db.VarChar(20)
  email               String?       @db.VarChar(150)
  address             String?       @db.VarChar(255)
  neighborhood        String?       @db.VarChar(100)
  city                String?       @db.VarChar(100)
  postal_code         String?       @db.VarChar(20)
  mother_name         String?       @db.VarChar(150)
  father_name         String?       @db.VarChar(150)
  company             String?       @db.VarChar(150)
  photo_url           String?
  created_at          DateTime?     @default(now()) @db.Timestamp(6)
  updated_at          DateTime?     @default(now()) @db.Timestamp(6)
  occurrences         occurrences[]
  courses             courses       @relation(fields: [course_id], references: [id], onUpdate: NoAction, map: "fk_students_course")
}

model reserve_classrooms {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classroom_id    String      @db.Uuid
  data            DateTime    @db.Date
  period          period_enum
  user_id         String      @db.VarChar(255)
  created_at      DateTime?   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?   @db.Timestamptz(6)
  user_name       String      @db.VarChar(200)
  course_type     String      @db.VarChar(100)
  number_students Int?        @db.SmallInt
  course_name     String?     @db.VarChar(150)
  classrooms      classrooms  @relation(fields: [classroom_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "reserve_classrooms_classrooms_id_fkey")
  users           users       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([classroom_id, data, period], map: "reserve_classrooms_classrooms_id_data_period_key")
}

model occurrences {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id  String    @db.Uuid
  type        String    @db.VarChar(100)
  description String
  date        DateTime  @db.Timestamptz(6)
  user_id     String    @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @db.Timestamptz(6)
  user_name   String    @db.VarChar(200)
  students    students  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_incidents_student")
  users       users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_incidents_user")
}

model student_referral_comments {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referral_id       String            @db.Uuid
  author_id         String            @db.VarChar(255)
  author_name       String            @db.VarChar(255)
  comment           String
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  users             users             @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  student_referrals student_referrals @relation(fields: [referral_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model student_referrals {
  id                                             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_name                                   String                      @db.VarChar(255)
  reason                                         String                      @db.VarChar(255)
  description                                    String
  status                                         String?                     @default("aberto") @db.VarChar(50)
  created_by_id                                  String                      @db.VarChar(255)
  created_by_name                                String                      @db.VarChar(255)
  assigned_to_id                                 String?                     @db.VarChar(255)
  assigned_to_name                               String?                     @db.VarChar(255)
  finalized_by_id                                String?                     @db.VarChar(255)
  finalized_by_name                              String                      @db.VarChar(255)
  created_at                                     DateTime?                   @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime?                   @default(now()) @db.Timestamptz(6)
  finalized_at                                   DateTime?                   @db.Timestamptz(6)
  student_referral_comments                      student_referral_comments[]
  users_student_referrals_assigned_to_idTousers  users?                      @relation("student_referrals_assigned_to_idTousers", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_student_referrals_created_by_idTousers   users                       @relation("student_referrals_created_by_idTousers", fields: [created_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_student_referrals_finalized_by_idTousers users?                      @relation("student_referrals_finalized_by_idTousers", fields: [finalized_by_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model notifications {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.VarChar(255)
  title       String    @db.VarChar(255)
  message     String
  type        String    @db.VarChar(50)
  entity_id   String?   @db.Uuid
  entity_type String?   @db.VarChar(50)
  read        Boolean?  @default(false)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  users       users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum period_enum {
  MANHA
  TARDE
  NOITE
}
